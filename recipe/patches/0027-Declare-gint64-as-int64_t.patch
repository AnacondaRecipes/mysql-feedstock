From b44e47d44eab206f763824fff9eff3e40da7ad1b Mon Sep 17 00:00:00 2001
From: Mikolaj Gralczyk <mgralczyk@anaconda.com>
Date: Fri, 28 Nov 2025 10:37:49 +0100
Subject: [PATCH] Declare gint64 as int64_t

google::protobuf::int64 is not available in newer protobuf versions.
The base class ZeroCopyInputStream::ByteCount() returns int64_t,
replacing google::protobuf::int64 with int64_t
---
 plugin/x/client/stream/connection_input_stream.h      | 3 ++-
 plugin/x/client/stream/connection_output_stream.h     | 3 ++-
 plugin/x/protocol/stream/decompression_input_stream.h | 3 ++-
 plugin/x/src/io/vio_input_stream.h                    | 3 ++-
 4 files changed, 8 insertions(+), 4 deletions(-)

diff --git a/plugin/x/client/stream/connection_input_stream.h b/plugin/x/client/stream/connection_input_stream.h
index f2b8dac9..42c68d8a 100644
--- a/plugin/x/client/stream/connection_input_stream.h
+++ b/plugin/x/client/stream/connection_input_stream.h
@@ -28,6 +28,7 @@
 
 #include <google/protobuf/io/zero_copy_stream.h>
 #include <algorithm>
+#include <cstdint>
 #include <memory>
 
 #include "my_dbug.h"
@@ -40,7 +41,7 @@ namespace xcl {
 class Connection_input_stream
     : public google::protobuf::io::ZeroCopyInputStream {
  public:
-  using pb_int64 = google::protobuf::int64;
+  using pb_int64 = int64_t;
 
  public:
   explicit Connection_input_stream(XConnection *connection)
diff --git a/plugin/x/client/stream/connection_output_stream.h b/plugin/x/client/stream/connection_output_stream.h
index 5898ea61..a0b9c830 100644
--- a/plugin/x/client/stream/connection_output_stream.h
+++ b/plugin/x/client/stream/connection_output_stream.h
@@ -29,6 +29,7 @@
 #include <google/protobuf/io/zero_copy_stream.h>
 #include <zlib.h>
 
+#include <cstdint>
 #include <memory>
 #include <utility>
 
@@ -40,7 +41,7 @@ class Connection_output_stream
     : public google::protobuf::io::ZeroCopyOutputStream {
  public:
   using ZeroCopyOutputStream = google::protobuf::io::ZeroCopyOutputStream;
-  using pb_int64 = google::protobuf::int64;
+  using pb_int64 = int64_t;
 
  public:
   explicit Connection_output_stream(XConnection *connection)
diff --git a/plugin/x/protocol/stream/decompression_input_stream.h b/plugin/x/protocol/stream/decompression_input_stream.h
index f16cfc93..d5cf9e0b 100644
--- a/plugin/x/protocol/stream/decompression_input_stream.h
+++ b/plugin/x/protocol/stream/decompression_input_stream.h
@@ -26,6 +26,7 @@
 #define PLUGIN_X_PROTOCOL_STREAM_DECOMPRESSION_INPUT_STREAM_H_
 
 #include "google/protobuf/io/zero_copy_stream.h"
+#include <cstdint>
 
 #include "my_dbug.h"
 
@@ -93,7 +94,7 @@ class Decompression_input_stream
     return Skip(count - left);
   }
 
-  google::protobuf::int64 ByteCount() const override {
+  int64_t ByteCount() const override {
     return m_all + m_output_buffer_offset;
   }
 
diff --git a/plugin/x/src/io/vio_input_stream.h b/plugin/x/src/io/vio_input_stream.h
index 8269d38d..875956df 100644
--- a/plugin/x/src/io/vio_input_stream.h
+++ b/plugin/x/src/io/vio_input_stream.h
@@ -28,6 +28,7 @@
 
 #include <google/protobuf/io/zero_copy_stream.h>
 #include <my_inttypes.h>
+#include <cstdint>
 #include <memory>
 
 #include "plugin/x/src/interface/vio.h"
@@ -36,7 +37,7 @@ namespace xpl {
 
 class Vio_input_stream : public google::protobuf::io::ZeroCopyInputStream {
  public:
-  using gint64 = google::protobuf::int64;
+  using gint64 = int64_t;
 
  public:
   explicit Vio_input_stream(const std::shared_ptr<iface::Vio> &connection);
-- 
